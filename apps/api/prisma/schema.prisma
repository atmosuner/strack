generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum HouseholdRole {
  OWNER
  MEMBER
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String?
  stripeCustomerId String? @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships HouseholdMember[]
  pushTokens  PushToken[]
  reminderPref ReminderPref?
}

enum SubscriptionStatus {
  NONE
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELLED
}

model Household {
  id                  String             @id @default(uuid())
  name                String
  icsToken            String?            @unique
  stripeSubscriptionId String?           @unique
  subscriptionStatus  SubscriptionStatus @default(NONE)
  featureFlags        String             @default("{}")
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  members     HouseholdMember[]
  children    Child[]
  providers   Provider[]
  lessons     Lesson[]
  invitations Invitation[]
  payments    StripePayment[]
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REVOKED
}

model Invitation {
  id          String           @id @default(uuid())
  householdId String
  email       String
  token       String           @unique @default(uuid())
  role        HouseholdRole    @default(MEMBER)
  status      InvitationStatus @default(PENDING)
  invitedBy   String
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@unique([householdId, email])
  @@index([token])
}

model Child {
  id          String   @id @default(uuid())
  householdId String
  name        String
  notes       String?
  archived    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  lessons   Lesson[]

  @@index([householdId])
}

model Provider {
  id            String   @id @default(uuid())
  householdId   String
  name          String
  notes         String?
  archived      Boolean  @default(false)
  creditBalance Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  lessons   Lesson[]

  @@index([householdId])
}

enum PaymentStatus {
  UNPAID
  PAID
}

model Lesson {
  id             String        @id @default(uuid())
  householdId    String
  childId        String
  providerId     String
  title          String
  startAt        DateTime
  endAt          DateTime
  location       String?
  notes          String?
  recurrenceRule String?
  seriesId       String?
  exceptionDate  DateTime?
  cancelled      Boolean       @default(false)
  paymentStatus  PaymentStatus @default(UNPAID)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  household  Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  child      Child     @relation(fields: [childId], references: [id], onDelete: Cascade)
  provider   Provider  @relation(fields: [providerId], references: [id], onDelete: Cascade)
  series     Lesson?   @relation("LessonSeries", fields: [seriesId], references: [id], onDelete: Cascade)
  exceptions Lesson[]  @relation("LessonSeries")

  @@index([householdId])
  @@index([childId])
  @@index([providerId])
  @@index([householdId, startAt])
  @@index([seriesId])
}

model HouseholdMember {
  id          String         @id @default(uuid())
  role        HouseholdRole
  householdId String
  userId      String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([householdId, userId])
  @@index([userId])
}

// ── T11: Push notifications & reminders ──

model PushToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  platform  String   @default("expo")
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ReminderPref {
  id             String   @id @default(uuid())
  userId         String   @unique
  enabled        Boolean  @default(true)
  minutesBefore  Int      @default(30)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SentReminder {
  id            String   @id @default(uuid())
  userId        String
  lessonId      String
  occurrenceDate String
  sentAt        DateTime @default(now())

  @@unique([userId, lessonId, occurrenceDate])
}

// ── T12: Stripe payments ──

model StripePayment {
  id                  String   @id @default(uuid())
  householdId         String
  stripeSessionId     String   @unique
  stripePaymentIntent String?
  amountCents         Int
  currency            String   @default("usd")
  status              String   @default("pending")
  description         String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@index([householdId])
}
